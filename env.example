# Site URL (required in production)
NEXT_PUBLIC_SITE_URL=https://labs.picoids.com

# Email — Microsoft Graph API (same as picoids.com contact form)
EMAIL_USER=your-email@yourdomain.com
MICROSOFT_TENANT_ID=your-tenant-id-here
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here

# reCAPTCHA v3 — add labs.picoids.com to allowed domains
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here
